---
import ServicePageLayout from '../../layouts/ServicePageLayout.astro';

const page = {
  title: "Jasa Bore Pile Hydraulic",
  subtitle: "Solusi pondasi dalam dengan kapasitas beban ekstrem dan efisiensi tinggi.",
  mainIcon: "/assets/img/gallery/4.png",
  price: "Rp190.000 / m¹",
  key_features: [
    {
      icon: "fa-truck-monster",
      title: "Kekuatan Maksimal",
      description: "Ideal untuk menopang beban struktur yang sangat besar, seperti gedung pencakar langit dan jembatan."
    },
    {
      icon: "fa-tachometer-alt",
      title: "Pengerjaan Cepat",
      description: "Mesin hydraulic modern memungkinkan proses pengeboran yang jauh lebih cepat dibandingkan metode lain."
    },
    {
      icon: "fa-ruler-vertical",
      title: "Kedalaman Superior",
      description: "Mampu mencapai kedalaman puluhan meter untuk menjangkau lapisan tanah keras yang paling stabil."
    }
  ],
  process: [
    { step: 1, title: "Mobilisasi & Persiapan", description: "Alat berat hydraulic rig diantar ke lokasi dan disiapkan di titik pengeboran." },
    { step: 2, title: "Pengeboran Hydraulic", description: "Mata bor auger rotary menekan dan memutar tanah, yang kemudian diangkat dari lubang." },
    { step: 3, title: "Instalasi Tulangan & Pipa Tremie", description: "Kerangka besi fabrikasi dan pipa untuk pengecoran dimasukkan ke dalam lubang." },
    { step: 4, title: "Pengecoran Beton", description: "Beton segar dipompa melalui pipa tremie dari dasar lubang hingga penuh." }
  ],
  gallery_images: [
    "/assets/img/hydraulic/hydraulic1.webp",
    "/assets/img/hydraulic/hydraulic2.webp",
    "/assets/img/hydraulic/hydraulic3.webp",
    "/assets/img/hydraulic/hydraulic4.webp",
    "/assets/img/hydraulic/hydraulic5.webp",
    "/assets/img/hydraulic/hydraulic6.webp"
  ]
};

// SEO and Keywords
const seo = {
  title: "Jasa Bore Pile Hydraulic Profesional | Hadiwijaya Pondasi Persada",
  description: "Layanan bore pile hydraulic dari Hadiwijaya Pondasi Persada untuk proyek skala besar dan masif. Solusi pondasi cepat dan efisien untuk gedung tinggi, jembatan, dan infrastruktur. Hubungi untuk estimasi biaya.",
};

const existingKeywords = ["jasa bore pile hydraulic", "harga bore pile hydraulic", "biaya bore pile hydraulic", "pondasi gedung tinggi", "pondasi jembatan", "pondasi tower", "hydraulic drilling rig", "kontraktor hydraulic bore pile", "pondasi industri berat"];

const newKeywords = [
  "bore pile adalah", "bore pile jakarta", "bore pile pondasi", "harga bore pile", 
  "harga bore pile diameter 40 cm", "harga jasa bore pile", "harga jasa bore pile per meter", 
  "jasa bore pile jakarta", "jasa bore pile manual", "jasa bore pile murah", 
  "jasa bore pile semarang", "jasa bore pile strauss pile", "jasa bore pile tangerang", 
  "jasa strauss pile", "jasa strauss pile jakarta", "pondasi strauss pile",
  "harga bore pile diameter 30 cm", "harga bore pile per meter", "jasa bor pile manual", 
  "harga bor pile per titik", "harga bore pile per titik", "harga borongan bore pile", 
  "harga bore pile diameter 80 cm", "alat bore pile", "ukuran bore pile", 
  "bored pile pondasi", "pile boring machine", "alat bore pile manual", "casing bore pile", 
  "detail pondasi bore pile", "mesin bore pile", "pondasi bore pile adalah", 
  "ukuran pondasi bore pile", "gambar pondasi bore pile", "apa itu bore pile", 
  "bore pile surabaya", "pekerjaan bore pile", "denah pondasi bore pile", 
  "detail bore pile", "jasa bore pile bogor"
];

const keywords = [...new Set([...existingKeywords, ...newKeywords])];

const contentHtml = `
  <h2>Deskripsi Layanan</h2>
  <p>
    <strong>Jasa Bore Pile Hydraulic</strong> adalah puncak dari teknologi pondasi dalam. Menggunakan mesin Hydraulic Rotary Drilling Rig, metode ini dirancang untuk proyek-proyek yang menuntut kekuatan, kedalaman, dan efisiensi tertinggi. Dengan kemampuan mengebor diameter besar (60 cm hingga 200 cm) dan mencapai kedalaman ekstrem, ini adalah pilihan utama untuk struktur-struktur ikonik dan infrastruktur vital.
  </p>
  <p>
    Keunggulan utama dari sistem hydraulic adalah kecepatan dan presisinya. Proses pengeboran yang cepat secara signifikan mengurangi waktu konstruksi, sementara sistem kontrol modern memastikan setiap lubang dibuat dengan akurasi vertikal yang sempurna. Metode ini sangat efektif pada berbagai kondisi tanah, termasuk tanah keras dan berbatu, menjadikannya solusi yang sangat andal untuk proyek-proyek paling menantang.
  </p>
  <h3>Kelebihan Bore Pile Hydraulic:</h3>
  <ul>
    <li><strong>Kapasitas Beban Tertinggi:</strong> Dirancang untuk menopang beban aksial dan lateral yang masif.</li>
    <li><strong>Efisiensi Waktu:</strong> Proses pengeboran paling cepat, mempercepat jadwal proyek secara keseluruhan.</li>
    <li><strong>Minim Getaran:</strong> Proses rotary mengurangi getaran, lebih aman untuk lingkungan sekitar dibandingkan tiang pancang.</li>
    <li><strong>Akurasi Tinggi:</strong> Mampu menghasilkan lubang bor yang presisi sesuai dengan desain teknis.</li>
  </ul>
`;
---

<ServicePageLayout 
  frontmatter={page} 
  title={seo.title} 
  description={seo.description} 
  keywords={keywords}
  contentHtml={contentHtml}
/>
