---
import ServicePageLayout from '../../layouts/ServicePageLayout.astro';

const page = {
  title: "Jasa Bore Pile Mini Crane",
  subtitle: "Fleksibilitas tinggi untuk area terbatas dengan kekuatan pondasi yang andal.",
  mainIcon: "/assets/img/gallery/1.jpg", 
  price: "Rp140.000 / m¹",
  key_features: [
    {
      icon: "fa-compress-arrows-alt",
      title: "Akses Lokasi Sulit",
      description: "Desainnya yang ringkas memungkinkan mobilisasi di area yang sempit atau sulit dijangkau alat berat."
    },
    {
      icon: "fa-check-circle",
      title: "Kekuatan Terjamin",
      description: "Mampu menghasilkan pondasi yang kuat dan stabil untuk bangunan 2 hingga 5 lantai."
    },
    {
      icon: "fa-leaf",
      title: "Dampak Lingkungan Rendah",
      description: "Getaran dan kebisingan yang dihasilkan lebih minim, ideal untuk area padat penduduk."
    }
  ],
  process: [
    { step: 1, title: "Setup Tripod & Winch", description: "Rangka tripod baja diposisikan di atas titik bor, dan mesin winch (derek) disiapkan." },
    { step: 2, title: "Pengeboran Auger", description: "Mata bor auger diturunkan dan diputar untuk menggali tanah. Dilakukan berulang kali hingga kedalaman tercapai." },
    { step: 3, title: "Pemasangan Tulangan Besi", description: "Kerangka besi yang telah dirakit dimasukkan ke dalam lubang bor sebagai struktur utama." },
    { step: 4, title: "Pengecoran", description: "Beton segar dituangkan ke dalam lubang bor hingga penuh, biasanya menggunakan talang atau metode manual." }
  ],
  gallery_images: [
    "/assets/img/minicrane/minicrane1.webp",
    "/assets/img/minicrane/minicrane2.webp",
    "/assets/img/minicrane/minicrane3.webp",
    "/assets/img/minicrane/minicrane4.webp",
    "/assets/img/minicrane/minicrane5.webp",
    "/assets/img/minicrane/minicrane6.webp"
  ]
};

// SEO and Keywords
const seo = {
  title: "Jasa Bore Pile Mini Crane | Solusi Pondasi Lahan Sempit | Hadiwijaya",
  description: "Hadiwijaya Pondasi Persada menyediakan jasa bore pile mini crane, solusi efektif untuk pondasi di lokasi terbatas seperti ruko, perumahan, dan gudang. Menjamin kekuatan untuk bangunan 2-5 lantai dengan getaran minim. Dapatkan harga terbaik.",
};

const existingKeywords = ["jasa bore pile mini crane", "harga bore pile mini crane", "pondasi lahan sempit", "bore pile ruko", "bore pile perumahan", "bore pile mesin", "jasa pondasi mesin tripod", "pondasi minim getaran", "bore pile untuk gudang"];

const newKeywords = [
  "bore pile adalah", "bore pile jakarta", "bore pile pondasi", "harga bore pile", 
  "harga bore pile diameter 40 cm", "harga jasa bore pile", "harga jasa bore pile per meter", 
  "jasa bore pile jakarta", "jasa bore pile manual", "jasa bore pile murah", 
  "jasa bore pile semarang", "jasa bore pile strauss pile", "jasa bore pile tangerang", 
  "jasa strauss pile", "jasa strauss pile jakarta", "pondasi strauss pile",
  "harga bore pile diameter 30 cm", "harga bore pile per meter", "jasa bor pile manual", 
  "harga bor pile per titik", "harga bore pile per titik", "harga borongan bore pile", 
  "harga bore pile diameter 80 cm", "alat bore pile", "ukuran bore pile", 
  "bored pile pondasi", "pile boring machine", "alat bore pile manual", "casing bore pile", 
  "detail pondasi bore pile", "mesin bore pile", "pondasi bore pile adalah", 
  "ukuran pondasi bore pile", "gambar pondasi bore pile", "apa itu bore pile", 
  "bore pile surabaya", "pekerjaan bore pile", "denah pondasi bore pile", 
  "detail bore pile", "jasa bore pile bogor"
];

const keywords = [...new Set([...existingKeywords, ...newKeywords])];

const contentHtml = `
  <h2>Deskripsi Layanan</h2>
  <p>
    <strong>Jasa Bore Pile Mini Crane</strong> adalah solusi cerdas ketika kekuatan pondasi bore pile dibutuhkan di lokasi yang tidak dapat diakses oleh alat berat. Menggunakan sistem tripod (kaki tiga) yang kokoh dan mesin winch bertenaga, metode ini memungkinkan pengeboran yang efisien di area sempit, di dalam ruangan, atau di belakang bangunan.
  </p>
  <p>
    Meskipun ukurannya ringkas, bore pile mini crane mampu membuat lubang bor dengan diameter yang cukup besar (biasanya 30 cm hingga 60 cm) dan kedalaman yang memadai untuk menopang struktur bangunan bertingkat rendah hingga menengah. Ini adalah pilihan paling populer untuk pembangunan ruko, rumah tinggal mewah, dan gudang di kawasan perkotaan yang padat.
  </p>
  <h3>Kelebihan Bore Pile Mini Crane:</h3>
  <ul>
    <li><strong>Fleksibilitas Tinggi:</strong> Dapat dioperasikan di lokasi yang sangat terbatas atau sulit dijangkau.</li>
    <li><strong>Kekuatan Andal:</strong> Memberikan daya dukung yang jauh lebih superior dibandingkan pondasi dangkal.</li>
    <li><strong>Minim Gangguan:</strong> Proses kerja menghasilkan getaran dan kebisingan yang relatif rendah.</li>
    <li><strong>Cost-Effective:</strong> Biaya mobilisasi dan operasional lebih rendah dibandingkan metode hydraulic.</li>
  </ul>
`;
---

<ServicePageLayout 
  frontmatter={page} 
  title={seo.title} 
  description={seo.description} 
  keywords={keywords}
  contentHtml={contentHtml}
/>
